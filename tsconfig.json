{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./lib",
		"target": "esnext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": [
			"esnext"
		],
		"declaration": true,
		"strictNullChecks": true,
		"types": [
			"node"
		]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"test",
		"src/regex_editable.ts"
	]
}